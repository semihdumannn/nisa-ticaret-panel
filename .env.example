APP_NAME="Nisa Ticaret"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Neon PostgreSQL (Production Database)
DB_CONNECTION=pgsql
DB_HOST=ep-fragrant-cherry-alstwmya-pooler.c-3.eu-central-1.aws.neon.tech
DB_PORT=5432
DB_DATABASE=nisa-ticaret
DB_USERNAME=neondb_owner
DB_PASSWORD=npg_Pqm7TpvJOZa1
DB_SSLMODE=require

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=minio
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Redis (Docker)
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=http://minio:9000
MINIO_KEY=minio
MINIO_SECRET=minio123
MINIO_REGION=us-east-1
MINIO_BUCKET=nisa-ticaret
MINIO_USE_PATH_STYLE_ENDPOINT=true

# AWS S3 (Production alternative)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=

# Mail
MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@nisaticaret.com"
MAIL_FROM_NAME="${APP_NAME}"

# Firebase
FIREBASE_PROJECT_ID=nisa-ticaret
FIREBASE_CREDENTIALS=./firebase-credentials.json

# Filament
FILAMENT_FILESYSTEM_DISK=minio

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# Laravel Scout (full-text search)
SCOUT_DRIVER=database

# CORS — comma-separated allowed origins (* = all, use explicit domains in production)
CORS_ALLOWED_ORIGINS=*

# iyzico Payment Gateway
IYZICO_API_KEY=sandbox-api-key
IYZICO_SECRET_KEY=sandbox-secret-key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
